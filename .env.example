# ── Required ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Admin ─────────────────────────────────────────────────────────────────────
# Telegram user ID of the bot owner (prevents the /setadmin race on first start)
ADMIN_ID=123456789

# Username shown in payment instructions (without the @)
PAYMENT_ADMIN_USERNAME=your_admin_username

# ── Optional: MongoDB hit persistence ─────────────────────────────────────────
# If unset, hits are only stored locally in SQLite
MONGODB_URL=mongodb+srv://user:pass@cluster.mongodb.net/netflix_checker

# ── Optional: Telegram backup group ──────────────────────────────────────────
# Group/channel ID where the bot sends DB export backups (negative ID for groups)
BACKUP_CHAT_ID=-1001234567890

# ── Performance tuning ────────────────────────────────────────────────────────
# Number of proxies raced simultaneously per check (default: 6)
RACE_N=6

# Max concurrent cookie checks during a bulk run (default: 16)
BULK_CONCURRENCY=16

# ── Dashboard auth (optional but recommended) ─────────────────────────────────
# If set, the /api/stats endpoint requires this token as ?token=<value>
DASHBOARD_TOKEN=change_me_to_a_random_secret

# ── Cloudflare Worker relay (optional — routes checks through CF edge) ─────────
# Deploy cf_worker.js with wrangler, then paste your Worker URL here.
# When set, the CF relay is raced alongside normal proxies automatically.
# Example: https://netflix-proxy.your-name.workers.dev
CF_WORKER_URL=

# Secret key to protect your Worker from unauthorized use.
# Set the same value in: wrangler secret put PROXY_KEY
CF_PROXY_KEY=

# ── Database directory (for Docker / persistent disk deploys) ─────────────────
# SQLite databases are stored here. Default is current directory.
# For Docker: set to /data (matches the volume mount in docker-compose.yml)
# For Render with Persistent Disk: set to /data (mount the disk at /data)
DB_DIR=
